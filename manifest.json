{
  "name": "Cookie Crush",
  "description": "Crushes as many cookies as possible (by rejecting them)",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
	"default_popup": "default.html",
	"default_icon": "icon.png"
  },

  "icons": {
	"16": "icons/icon16.png",
	"32": "icons/icon32.png",
	"48": "icons/icon48.png",
	"128": "icons/icon128.png"
  },

  "content_scripts": [
	{
		"js": ["scripts/content_script.js"],
		"matches": [
			"<all_urls>"
		],
		"run_at": "document_start"
	}
  ],
  "background": {
	"service_worker": "scripts/worker.js",
	"type": "module"
  },

  "web_accessible_resources": [
	{
		"resources": ["rules.json"],
		"matches": ["<all_urls>"]
	}
  ],

  "permissions": ["activeTab", "scripting", "storage", "scripting"]
        
}